            <div style={{ background: 'linear-gradient(90deg, rgba(16,185,129,0.15) 0%, rgba(0,242,254,0.1) 100%)', padding: '16px 20px', borderRadius: '8px', border: '1px solid #10b981', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
              <div>
                <h4 style={{ color: '#4ade80', margin: 0, fontSize: '15px' }}>🎉 ¡Bienvenido! Tu código de descuento promocional está activo</h4>
                <p style={{ margin: '4px 0 0 0', fontSize: '13px', color: '#94a3b8' }}>Úsalo en la sección de Órdenes para aplicar una rebaja del 10% instantánea.</p>
              </div>
              <div style={{ background: '#111827', padding: '8px 16px', borderRadius: '4px', border: '1px dashed #00f2fe', fontFamily: 'monospace', fontSize: '16px', fontWeight: 'bold', color: '#00f2fe' }}>
                {generatedWelcomeCoupon}
              </div>
            </div>
          )}

          <div style={{display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(240px, 1fr))', gap: '20px'}}>
            <div className="content-card" style={{borderLeft: '4px solid #00f2fe', padding: '20px'}}>
              <p style={{color: '#94a3b8', fontSize: '12px', textTransform: 'uppercase', letterSpacing: '1px'}}>Stock Total en Bodegas</p>
              <h3 style={{fontSize: '32px', color: '#fff', marginTop: '10px'}}>{totalProductosFisicos} <span style={{fontSize: '14px', color: '#00f2fe'}}>Unidades</span></h3>
            </div>
            
            <div className="content-card" style={{borderLeft: '4px solid #ff9f43', padding: '20px'}}>
              <p style={{color: '#94a3b8', fontSize: '12px', textTransform: 'uppercase', letterSpacing: '1px'}}>Ingresos Facturados</p>
              <h3 style={{fontSize: '32px', color: '#fff', marginTop: '10px'}}>
                ${Math.round(totalMontoOrdenes).toLocaleString("es-CL")} {discountApplied && <span style={{fontSize:'14px', color:'#4ade80'}}>(Descuento 10% Canjeado)</span>}
              </h3>
            </div>

            <div className="content-card" style={{borderLeft: '4px solid #10b981', padding: '20px'}}>
              <p style={{color: '#94a3b8', fontSize: '12px', textTransform: 'uppercase', letterSpacing: '1px'}}>Despachos Activos</p>
              <h3 style={{fontSize: '32px', color: '#fff', marginTop: '10px'}}>{enviosPendientes} <span style={{fontSize: '14px', color: '#10b981'}}>En Curso</span></h3>
            </div>
          </div>

          <div style={{display: 'grid', gridTemplateColumns: '2fr 1fr', gap: '20px', minHeight: '300px'}}>
            <div className="content-card" style={{ maxHeight: '420px', overflowY: 'auto' }}>
              <h2>Capacidad y Distribución de Bodegas</h2>
              <div style={{display: 'flex', flexDirection: 'column', gap: '15px', marginTop: '20px'}}>
                {inventarioData.map((item, idx) => {
                  const porcentaje = Math.min((item.cantidad / 300) * 100, 100);
                  return (
                    <div key={idx}>
                      <div style={{display: 'flex', justifyContent: 'space-between', fontSize: '12px', marginBottom: '5px'}}>
                        <span style={{color: item.cantidad === 0 ? '#ef4444' : '#cbd5e1', fontWeight: item.cantidad === 0 ? 'bold' : 'normal'}}>
                          {item.producto} ({item.bodega}) {item.cantidad === 0 && '⚠️ AGOTADO'}
                        </span>
                        <span style={{color: '#00f2fe', fontFamily: 'monospace'}}>{item.cantidad} / 300 uds</span>
                      </div>
                      <div style={{width: '100%', background: '#111827', height: '10px', borderRadius: '5px', overflow: 'hidden'}}>
                        <div style={{width: `${porcentaje}%`, background: item.cantidad === 0 ? '#ef4444' : 'linear-gradient(90deg, #00f2fe, #4facfe)', height: '100%', borderRadius: '5px', transition: 'width 0.5s ease'}}></div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* 2) CUADRADITO DE NOMBRE Y CORREO DEL USUARIO ADAPTADO */}
            <div className="content-card" style={{display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', textAlign: 'center'}}>
              <div style={{width: '80px', height: '80px', borderRadius: '50%', background: 'linear-gradient(135deg, #00f2fe 0%, #4facfe 100%)', display: 'flex', justifyContent: 'center', alignItems: 'center', fontSize: '32px', color: '#000', fontWeight: 'bold', marginBottom: '16px'}}>
                {activeUsername.charAt(0).toUpperCase()}
              </div>
              <h2 style={{fontSize: '20px', color: '#fff', marginBottom: '4px'}}>{activeUsername}</h2>
              <p style={{color: '#94a3b8', fontSize: '14px', marginBottom: '12px', wordBreak: 'break-all'}}>{activeEmail}</p>
              <p style={{color: '#00f2fe', fontSize: '12px', textTransform: 'uppercase', letterSpacing: '1px', marginBottom: '20px', fontWeight: '600'}}>Control General</p>
            </div>
          </div>
        </div>
      )}

      {/* ==========================================
          VISTA DE PESTAÑA: INVENTARIO
         ========================================== */}
      {currentTab === 'inventario' && (
        <div className="content-card">
          <div style={{display:'flex', justifyContent:'space-between', marginBottom:'20px'}}>
            <h2>Inventario Físico Tecnológico</h2>
            <button className="crud-btn add" onClick={() => openModalForAdd('add_inventario')}>+ Registrar Producto</button>
          </div>
          <table className="data-table">
            <thead>
              <tr>
                <th>SKU</th><th>Producto</th><th>Bodega</th><th>Cantidad</th><th>Estado</th><th style={{ textAlign: 'right' }}>Costo Unitario</th><th style={{ textAlign: 'center' }}>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {inventarioData.map((item, idx) => (
                <tr key={idx} style={{backgroundColor: item.cantidad === 0 ? 'rgba(239, 68, 68, 0.1)' : 'transparent'}}>
                  <td style={{fontFamily:'monospace', color:'#00f2fe'}}>{item.sku}</td>
                  <td>{item.producto}</td>
                  <td>{item.bodega}</td>
                  <td><strong>{item.cantidad}</strong></td>
                  <td>
                    <span style={{
                      backgroundColor: item.cantidad === 0 ? '#ef4444' : (item.cantidad < 40 ? '#ff9f43' : '#10b981'),
                      color: '#fff', padding: '4px 8px', borderRadius: '4px', fontSize: '11px', fontWeight: 'bold'
                    }}>
                      {item.cantidad === 0 ? 'Quiebre Stock' : (item.cantidad < 40 ? 'Poco Stock' : 'Disponible')}
                    </span>
                  </td>
                  <td style={{ textAlign: 'right', fontWeight: 'bold', color: '#10b981' }}>${Number(item.precio || 0).toLocaleString()}</td>
                  <td style={{ textAlign: 'center' }}>
                    <div style={{ display: 'flex', gap: '8px', justifyContent: 'center' }}>
                      <button className="crud-action-btn edit" style={{ margin: 0 }} onClick={() => openModalForEdit('edit_inventario', idx, item)}>Editar / Surtir</button>
                      <button className="crud-action-btn delete" style={{ margin: 0 }} onClick={() => handleDeleteInventario(idx)}>Eliminar</button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {/* ==========================================
          VISTA DE PESTAÑA: ÓRDENES
         ========================================== */}
      {currentTab === 'ordenes' && (
        <div className="content-card">
          <div style={{display:'flex', justifyContent:'space-between', marginBottom:'20px'}}>
            <h2>Órdenes de Compra en Base de Datos</h2>
            <button className="crud-btn add" onClick={() => openModalForAdd('add_orden')}>+ Crear Nueva Órden</button>
          </div>

          <div style={{ background: "#111827", padding: "20px", borderRadius: "8px", border: "1px solid #1f2937", marginBottom: "25px" }}>
            <h3 style={{ color: "#00f2fe", margin: "0 0 10px 0" }}>🎁 Validación de Código Promocional</h3>
            <p style={{ fontSize: "13px", color: "#9ca3af" }}>Ingresa tu cupón para aplicar una rebaja directa del 10% en todos los ingresos calculados del Dashboard.</p>
            
            <form onSubmit={handleApplyCouponSubmit} style={{ display: "flex", gap: "10px", marginTop: "15px", alignItems: "center", maxWidth: "450px" }}>
              <input 
                type="text" 
                placeholder="INGRESA TU CÓDIGO AQUÍ" 
                value={typedCode} 
                onChange={(e) => setTypedCode(e.target.value)} 
                disabled={discountApplied} 
                style={{ margin: 0, textTransform: "uppercase", width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} 
              />
              <button 
                type="submit" 
                disabled={discountApplied} 
                className="crud-btn add" 
                style={{ margin: 0, width: "auto", padding: "0 20px", height: "42px" }}
              >
                {discountApplied ? "Aplicado" : "Validar"}
              </button>
            </form>
            {qrMessage && <p style={{ marginTop: "10px", fontSize: "13px", color: qrStatus === "success" ? "#4ade80" : "#ef4444", fontWeight: 'bold' }}>{qrMessage}</p>}
          </div>

          <table className="data-table">
            <thead>
              <tr><th>N° Órden</th><th>Estado</th><th>Tracking</th><th>Productos (SKU-Cant)</th><th>Monto Total</th><th>Acciones</th></tr>
            </thead>
            <tbody>
              {ordenesData.length === 0 ? (
                <tr><td colSpan="6" style={{textAlign:'center', padding:'20px', color:'#666'}}>No hay órdenes en cola.</td></tr>
              ) : (
                ordenesData.map((order, idx) => {
                  // 3) Cálculo del precio individual de la orden menos el 10% si corresponde
                  const montoFinalOrden = discountApplied ? Number(order.totalAmount) * 0.9 : Number(order.totalAmount);
                  
                  return (
                    <tr key={idx}>
                      <td style={{fontFamily:'monospace', color:'#00f2fe', fontWeight:'bold'}}>{order.orderNumber}</td>
                      <td><span>{order.status}</span></td>
                      <td>{order.trackingCode || "No asignado"}</td>
                      <td>
                        {order.lines && order.lines.map((l, i) => {
                          const prod = inventarioData.find(p => p.sku === l.sku);
                          return <div key={i}>{prod ? prod.producto : l.sku} <span style={{color:'#ff9f43'}}>(x{l.quantity})</span></div>;
                        })}
                      </td>
                      <td>
                        <strong style={{ color: discountApplied ? '#4ade80' : '#fff' }}>
                          ${Math.round(montoFinalOrden).toLocaleString()}
                        </strong>
                        {discountApplied && <span style={{display: 'block', fontSize: '11px', color: '#a3e635'}}>(10% OFF aplicado)</span>}
                      </td>
                      <td>
                        <button className="crud-action-btn edit" onClick={() => openModalForEdit('edit_orden', idx, order)}>Editar</button>
                        <button className="crud-action-btn delete" onClick={() => handleDeleteOrderLocal(order.orderNumber, idx)}>Eliminar</button>
                      </td>
                    </tr>
                  );
                })
              )}
            </tbody>
          </table>
        </div>
      )}

      {/* ==========================================
          VISTA DE PESTAÑA: ENVÍOS
         ========================================== */}
      {currentTab === 'envios' && (
        <div className="content-card">
          <div style={{display:'flex', justifyContent:'space-between', marginBottom:'20px'}}>
            <h2>Seguimiento Logístico de Rutas</h2>
            <button className="crud-btn add" onClick={() => openModalForAdd('add_envio')}>+ Generar Despacho</button>
          </div>
          <table className="data-table">
            <thead>
              <tr><th>Tracking</th><th>N° Orden</th><th>Carrier</th><th>Origen</th><th>Dirección Destino</th><th>Código Ruta</th><th>Estado</th><th>Acciones</th><th style={{textAlign: 'center', color: '#00f2fe'}}>Módulo Adaptador</th></tr>
            </thead>
            <tbody>
              {enviosData.length === 0 ? (
                <tr><td colSpan="9" style={{textAlign:'center', padding:'20px', color:'#666'}}>Sin despachos registrados.</td></tr>
              ) : (
                enviosData.map((ship, idx) => (
                  <tr key={idx}>
                    <td style={{fontFamily:'monospace', color:'#00f2fe'}}>{ship.trackingCode}</td>
                    <td>{ship.orderNumber}</td>
                    <td><strong style={{color: '#ff9f43'}}>{ship.carrier}</strong></td>
                    <td>{ship.origen}</td>
                    <td>{ship.destino}</td>
                    <td><span style={{fontFamily:'monospace'}}>{ship.routeCode || "Sin procesar"}</span></td>
                    <td><span>{ship.status}</span></td>
                    <td>
                      <div style={{ display: 'flex', gap: '8px' }}>
                        <button className="crud-action-btn edit" style={{ margin: 0 }} onClick={() => openModalForEdit('edit_envio', idx, ship)}>Editar</button>
                        <button className="crud-action-btn delete" style={{ margin: 0 }} onClick={() => handleDeleteEnvio(idx)}>Eliminar</button>
                      </div>
                    </td>
                    <td style={{ textAlign: 'center' }}>
                      <button type="button" className="crud-btn add" onClick={() => handleAdaptarRutaBackend(idx, ship)} disabled={adaptingIndex !== null} style={{ margin: 0, fontSize: '12px', padding: '6px 12px' }}>
                        {adaptingIndex === idx ? "⏳ Evaluando..." : "⚙️ Adaptar Ruta"}
                      </button>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      )}

      {/* MODAL RESPONSIVO DEL ADAPTADOR LOGÍSTICO */}
      {adaptationResult && (
        <div className="modal-overlay" style={{ background: 'rgba(0,0,0,0.85)', display: 'flex', justifyContent: 'center', alignItems: 'center', zIndex: 3500 }}>
          <div className="modal-content" style={{ border: '2px solid #00f2fe', width: '440px', padding: '25px' }}>
            <h3 style={{ color: "#00f2fe", marginTop: 0 }}>🔄 Adaptador de Ruta Activo</h3>
            <p style={{ fontSize: '14px', color: '#e2e8f0', margin: '15px 0' }}>Parámetros de transporte procesados:</p>
            <div style={{ background: '#111827', padding: '12px', borderRadius: '6px', textAlign: 'left', fontSize: '13px', border: '1px solid #1f2937', marginBottom: '20px' }}>
              <p>📍 Transportista Sugerido: <strong style={{color:'#ff9f43'}}>{adaptationResult.mejorEmpresa}</strong></p>
              <p>🔀 Identificador de Ruta: <strong style={{color:'#00f2fe'}}>{adaptationResult.nuevaRuta}</strong></p>
              <p style={{color: '#94a3b8', marginTop: '8px', fontStyle: 'italic'}}>💡 Log: {adaptationResult.detalle}</p>
            </div>
            <button type="button" className="crud-btn add" style={{ width: '100%' }} onClick={() => setAdaptationResult(null)}>Sincronizar Ruta</button>
          </div>
        </div>
      )}

      {/* 4) ALERTA DE STOCK CRÍTICO CORREGIDA */}
      {showAlertPopup && listadoCriticos.length > 0 && (
        <div className="modal-overlay" style={{ background: 'rgba(0,0,0,0.85)', display: 'flex', justifyContent: 'center', alignItems: 'center', zIndex: 3000 }}>
          <div className="modal-content" style={{ border: '2px solid #ef4444', width: '450px', padding: '25px', borderRadius: '8px' }}>
            <h3 style={{ color: "#ef4444", marginBottom: "15px", marginTop: 0 }}>⚠️ ALERTA DE STOCK CRÍTICO</h3>
            <p style={{ fontSize: "14px", color: "#e2e8f0" }}>Los siguientes productos se encuentran totalmente agotados (Stock = 0):</p>
            <div style={{ background: '#111827', padding: '12px', maxHeight: '150px', overflowY: 'auto', margin: '15px 0' }}>
              {listadoCriticos.map((prod, index) => (
                <div key={index} style={{ display: 'flex', justifyContent: 'space-between', fontSize: '13px', padding: '5px 0' }}>
                  <span style={{ color: '#fca5a5' }}>{prod.producto}</span>
                  <span style={{ color: '#ef4444', fontFamily: 'monospace', fontWeight: 'bold' }}>AGOTADO</span>
                </div>
              ))}
            </div>
            <div style={{ display: 'flex', gap: '10px' }}>
              <button type="button" className="crud-btn add" style={{ flex: 1, backgroundColor: '#ef4444', color: '#fff' }} onClick={() => { setShowAlertPopup(false); handleTabChange('inventario'); }}>Ir a Surtir</button>
              <button type="button" className="btn-logout" style={{ borderRadius: '4px', margin: 0 }} onClick={() => setShowAlertPopup(false)}>Cerrar</button>
            </div>
          </div>
        </div>
      )}

      {/* MODALES CRUD DE ENTRADA GENERAL */}
      {showModal && (
        <div className="modal-overlay">
          <div className="modal-content">
            <h3>{modalType.startsWith('add') ? '➕ Agregar Registro' : '📝 Modificar'}</h3>
            <form onSubmit={handleModalSave} style={{marginTop:'15px'}}>
              {modalType.includes('inventario') && (
                <>
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="SKU" value={formInventario.sku} onChange={e => setFormInventario({...formInventario, sku: e.target.value})} required disabled={modalType === 'edit_inventario'} />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Producto" value={formInventario.producto} onChange={e => setFormInventario({...formInventario, producto: e.target.value})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Bodega" value={formInventario.bodega} onChange={e => setFormInventario({...formInventario, bodega: e.target.value})} required />
                  <input type="number" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Cantidad" value={formInventario.cantidad} onChange={e => setFormInventario({...formInventario, cantidad: parseInt(e.target.value) || 0})} required />
                  <input type="number" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Precio" value={formInventario.precio || 0} onChange={e => setFormInventario({...formInventario, precio: parseInt(e.target.value) || 0})} required />
                </>
              )}
              {modalType.includes('orden') && (
                <>
                  <input type="text" className="login-input" value={formOrden.orderNumber} readOnly style={{background:'#1f2937', color: '#fff'}} />
                  <select className="login-input" style={{background:'#1f2937', color:'#fff'}} value={getSelectedSkuSafe()} onChange={e => setFormOrden({...formOrden, selectedSku: e.target.value})}>
                    {inventarioData.map(item => <option key={item.sku} value={item.sku}>{item.producto} (Disponibles: {item.cantidad})</option>)}
                  </select>
                  <input type="number" style={{background: '#1f2937', color: '#fff'}} className="login-input" value={formOrden.orderQuantity} onChange={e => setFormOrden({...formOrden, orderQuantity: parseInt(e.target.value) || 1})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Tracking" value={formOrden.trackingCode} onChange={e => setFormOrden({...formOrden, trackingCode: e.target.value})} />
                  
                  {/* Visualización de los datos del comprador arriba del botón en el formulario modal */}
                  <div style={{background: '#111827', padding: '10px', borderRadius: '6px', border: '1px solid #374151', margin: '15px 0', fontSize: '13px', textAlign: 'left'}}>
                    <p style={{margin: 0, color: '#9ca3af'}}>👤 Comprador: <strong style={{color: '#00f2fe'}}>{activeUsername}</strong></p>
                    <p style={{margin: '4px 0 0 0', color: '#9ca3af'}}>✉️ Correo: <span style={{color: '#fff'}}>{activeEmail}</span></p>
                  </div>
                </>
              )}
              {modalType.includes('envio') && (
                <>
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Tracking" value={formEnvio.trackingCode} onChange={e => setFormEnvio({...formEnvio, trackingCode: e.target.value})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="N° Orden" value={formEnvio.orderNumber} onChange={e => setFormEnvio({...formEnvio, orderNumber: e.target.value})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Dirección de Destino Física" value={formEnvio.destino} onChange={e => setFormEnvio({...formEnvio, destino: e.target.value})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Carrier Actual" value={formEnvio.carrier} onChange={e => setFormEnvio({...formEnvio, carrier: e.target.value})} required />
                  <input type="text" style={{background: '#1f2937', color: '#fff'}} className="login-input" placeholder="Código de Ruta" value={formEnvio.routeCode} onChange={e => setFormEnvio({...formEnvio, routeCode: e.target.value})} required />
                </>
              )}
              <div style={{display:'flex', gap:'10px', marginTop:'20px'}}>
                <button type="submit" className="crud-btn add" style={{flex:1}}>Guardar</button>
                <button type="button" className="btn-logout" style={{flex:1, borderRadius:'4px'}} onClick={() => setShowModal(false)}>Cancelar</button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}
</file>

