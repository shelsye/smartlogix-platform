/* ==========================================
   CONFIGURACIÓN GENERAL Y VARIABLES (DARK/NEON)
   ========================================== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
  background-color: #050505;
  color: #e0e0e0;
}

/* ==========================================
   VISTA DE ACCESO: LOGIN Y REGISTRO
   ========================================== */
.login-bg {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: radial-gradient(circle at center, #0f172a 0%, #020617 100%);
}

.login-card {
  background: #0a0f1d;
  border: 1px solid rgba(0, 242, 254, 0.15);
  border-radius: 12px;
  padding: 40px;
  width: 100%;
  max-width: 400px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 15px rgba(0, 242, 254, 0.05);
}

.login-input {
  width: 100%;
  background: #111827;
  border: 1px solid #374151;
  color: #fff;
  padding: 12px 16px;
  border-radius: 6px;
  margin-bottom: 16px;
  font-size: 14px;
  transition: all 0.3s ease;
}

.login-input:focus {
  outline: none;
  border-color: #00f2fe;
  box-shadow: 0 0 8px rgba(0, 242, 254, 0.2);
}

.login-btn {
  width: 100%;
  background: transparent;
  border: 1px solid #00f2fe;
  color: #00f2fe;
  padding: 12px;
  border-radius: 6px;
  font-size: 15px;
  font-weight: bold;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.login-btn:hover {
  background: #00f2fe;
  color: #000;
  box-shadow: 0 0 15px rgba(0, 242, 254, 0.4);
}

.error-msg {
  color: #ff4a4a;
  background: rgba(255, 74, 74, 0.1);
  border: 1px solid rgba(255, 74, 74, 0.2);
  padding: 10px;
  border-radius: 6px;
  font-size: 13px;
  margin-bottom: 16px;
  text-align: center;
}

/* ==========================================
   ESTRUCTURA DEL PANEL PRINCIPAL (DASHBOARD)
   ========================================== */
.dashboard-layout {
  min-height: 100vh;
  background-color: #030712;
  padding: 24px;
}

/* Encabezado e Interfaz de Navegación */
.header-panel {
  display: flex;
  justify-content: space-between;
  align-items: center;
