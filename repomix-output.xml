    build:
      context: ./frontend/fron_smart_logix
      dockerfile: Dockerfile
    image: smartlogix/frontend:latest
    restart: unless-stopped
    depends_on:
      api-gateway:
        condition: service_healthy
    ports:
      - "80:80"
</file>

