          <h1>SmartLogix <span>Platform</span></h1>
          <p>Gestión de Operaciones e Interfaces de Control Dinámico</p>
        </div>
        <nav className="navbar-tabs">
          <button className={`tab-btn ${currentTab === 'dashboard' ? 'active' : ''}`} onClick={() => handleTabChange('dashboard')}>Dashboard</button>
          <button className={`tab-btn ${currentTab === 'inventario' ? 'active' : ''}`} onClick={() => handleTabChange('inventario')}>Inventario</button>
          <button className={`tab-btn ${currentTab === 'ordenes' ? 'active' : ''}`} onClick={() => handleTabChange('ordenes')}>Órdenes</button>
          <button className={`tab-btn ${currentTab === 'envios' ? 'active' : ''}`} onClick={() => handleTabChange('envios')}>Envíos</button>
        </nav>
        <button onClick={handleLogout} className="btn-logout">Cerrar sesión</button>
      </header>

      {/* ==========================================
          VISTA DE PESTAÑA: DASHBOARD
         ========================================== */}
