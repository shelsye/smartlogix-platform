import React, { useState, useEffect } from 'react';
import { getOrders, deleteOrder } from "./services/ordersService"; 
import { login, saveLoginSession } from "./services/authService";  
import { getShipments } from "./services/shipmentsService"; 
import './App.css';

export default function App() {
  // ==========================================
  // ESTADOS DE AUTENTICACIÓN Y NAVEGACIÓN (CON MEMORIA AL F5)
  // ==========================================
  const [isLoggedIn, setIsLoggedIn] = useState(() => {
    return localStorage.getItem("token") !== null;
  });
  
  const [currentTab, setCurrentTab] = useState(() => {
    return localStorage.getItem("activeTab") || 'dashboard';
  });

  const [isRegisterView, setIsRegisterView] = useState(false);
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [regEmail, setRegEmail] = useState('');
  const [regUsername, setRegUsername] = useState('');
  const [regPassword, setRegPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState(''); 
  const [loginError, setLoginError] = useState('');
  const [registerSuccess, setRegisterSuccess] = useState('');

  const [activeUsername, setActiveUsername] = useState(() => {
    return localStorage.getItem("active_username") || "Administrador";
  });

  const [activeEmail, setActiveEmail] = useState(() => {
    return localStorage.getItem("active_email") || "admin@smartlogix.cl";
  });

  // ==========================================
  // ESTADOS PARA MODALES Y CRUDS ORIGINALES
  // ==========================================
  const [showModal, setShowModal] = useState(false);
  const [modalType, setModalType] = useState(''); 
  const [selectedItemIndex, setSelectedItemIndex] = useState(null);
  const [showAlertPopup, setShowAlertPopup] = useState(false);

  const [formInventario, setFormInventario] = useState({ sku: '', producto: '', bodega: '', cantidad: 0, estado: 'Disponible', precio: 0 });
  const [formOrden, setFormOrden] = useState({ orderNumber: '', status: 'PENDIENTE', trackingCode: '', selectedSku: 'SKU-1001', orderQuantity: 1, totalAmount: 0 });
  const [formEnvio, setFormEnvio] = useState({ trackingCode: '', orderNumber: '', carrier: '', routeCode: '', status: 'PENDIENTE', origen: '', destino: '' });

  // ==========================================
  // AVANCE 2: ESTADOS DEL DESCUENTO AUTOMÁTICO DESDE BACKEND
  // ==========================================
  const [typedCode, setTypedCode] = useState(""); 
  const [qrMessage, setQrMessage] = useState("");
  const [qrStatus, setQrStatus] = useState(""); 
  const [discountApplied, setDiscountApplied] = useState(() => {
    return localStorage.getItem("discount_applied") === "true";
  });
  
  const [generatedWelcomeCoupon, setGeneratedWelcomeCoupon] = useState(() => {
    return localStorage.getItem("welcome_coupon") || "";
  });

  // ==========================================
  // AVANCE 1: ESTADOS DEL ADAPTADOR DE RUTA
  // ==========================================
  const [adaptingIndex, setAdaptingIndex] = useState(null);
  const [adaptationResult, setAdaptationResult] = useState(null);

  // ==========================================
  // DATOS LOCALES COMPLETOS (CON PERSISTENCIA EN LOCALSTORAGE PARA GUARDAR CAMBIOS)
  // ==========================================
  const [inventarioData, setInventarioData] = useState(() => {
    const local = localStorage.getItem("local_inventario");
    if (local) return JSON.parse(local);
    return [
      { sku: 'SKU-1001', producto: 'Teclado Mecánico RGB Corsair', bodega: 'WH-SCL-01', cantidad: 120, estado: 'Disponible', precio: 89990 },
      { sku: 'SKU-2001', producto: 'Mouse Inalámbrico Logitech G Pro', bodega: 'WH-SCL-01', cantidad: 200, estado: 'Disponible', precio: 119990 },
      { sku: 'SKU-3001', producto: 'Monitor ASUS ROG 24" 144Hz', bodega: 'WH-VAP-02', cantidad: 45, estado: 'Disponible', precio: 249990 },
      { sku: 'SKU-4004', producto: 'Tarjeta de Video RTX 4060 Ti', bodega: 'WH-SCL-01', cantidad: 28, estado: 'Poco Stock', precio: 489990 },
      { sku: 'SKU-5012', producto: 'Memoria RAM Kingston Fury 16GB', bodega: 'WH-VAP-02', cantidad: 150, estado: 'Disponible', precio: 45990 },
      { sku: 'SKU-6088', producto: 'Procesador AMD Ryzen 7 5700X', bodega: 'WH-SCL-01', cantidad: 62, estado: 'Disponible', precio: 199990 },
      { sku: 'SKU-7023', producto: 'Disco Duro SSD M.2 NVMe 1TB', bodega: 'WH-CCP-03', cantidad: 185, estado: 'Disponible', precio: 75990 },
      { sku: 'SKU-8055', producto: 'Gabinete Gamer MSI Forge 100M', bodega: 'WH-CCP-03', cantidad: 0, estado: 'Quiebre Stock', precio: 65000 }, 
      { sku: 'SKU-9099', producto: 'Fuente de Poder EVGA 750W Gold', bodega: 'WH-VAP-02', cantidad: 50, estado: 'Disponible', precio: 95000 },
      { sku: 'SKU-1122', producto: 'Audífonos HyperX Cloud Flight', bodega: 'WH-SCL-01', cantidad: 95, estado: 'Disponible', precio: 84990 }
    ];
  });
  
  const [ordenesData, setOrdenesData] = useState(() => {
    const local = localStorage.getItem("local_ordenes");
    return local ? JSON.parse(local) : [];
  });

  const [enviosData, setEnviosData] = useState(() => {
    const local = localStorage.getItem("local_envios");
    return local ? JSON.parse(local) : [];
  });  

  // Guardar en LocalStorage automáticamente ante cualquier cambio
  useEffect(() => {
    localStorage.setItem("local_inventario", JSON.stringify(inventarioData));
    
    // 4) VERIFICACIÓN AUTOMÁTICA DE STOCK: Si hay un producto en 0, detona la alerta inmediatamente
    const productosAgotados = inventarioData.filter(item => item.cantidad === 0);
    if (productosAgotados.length > 0) {
      setShowAlertPopup(true);
    }
  }, [inventarioData]);

  useEffect(() => {
    localStorage.setItem("local_ordenes", JSON.stringify(ordenesData));
  }, [ordenesData]);

  useEffect(() => {
    localStorage.setItem("local_envios", JSON.stringify(enviosData));
  }, [enviosData]);

  const handleTabChange = (tabName) => {
    setCurrentTab(tabName);
    localStorage.setItem("activeTab", tabName);
  };

  useEffect(() => {
    if (isLoggedIn) {
      if (ordenesData.length === 0) loadRealOrders();
      if (enviosData.length === 0) loadRealShipments();
    }
  }, [isLoggedIn]);

  const loadRealOrders = async () => {
    try {
      const data = await getOrders();
      if (data && data.length > 0) setOrdenesData(data);
    } catch (error) {
      console.error("Error cargando órdenes reales:", error);
    }
  };

  const loadRealShipments = async () => {
    try {
      const data = await getShipments();
      let listaProcesada = [];
      if (Array.isArray(data)) listaProcesada = data;
      else if (data && Array.isArray(data.content)) listaProcesada = data.content;
      
      if (listaProcesada.length > 0) {
        const mapeadoConDirecciones = listaProcesada.map(e => ({
          ...e,
          origen: e.origen || 'WH-SCL-01 (Bodega Central)',
          destino: e.destino || 'Av. Concha y Toro 1340, Puente Alto'
        }));
        setEnviosData(mapeadoConDirecciones);
      }
    } catch (error) {
      console.error("Error cargando envíos reales:", error);
    }
  };

  // ==========================================
  // AVANCE 1: CONEXIÓN REAL AL ADAPTADOR LOGÍSTICO (POST BACKEND)
  // Modificado para evaluar múltiples opciones por región buscando mejor precio y ruta
  // ==========================================
  const handleAdaptarRutaBackend = async (index, ship) => {
    setAdaptingIndex(index);
    setAdaptationResult(null);
    const token = localStorage.getItem("token");

    try {
      const headers = { 'Content-Type': 'application/json' };
      if (token) headers['Authorization'] = `Bearer ${token}`;

      const response = await fetch(`http://localhost:8080/api/shipments/${ship.trackingCode}/adapt-carrier`, {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ destino: ship.destino })
      });

      if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);
      const data = await response.json();

      setEnviosData(prev => {
        const updated = [...prev];
        updated[index] = {
          ...updated[index],
          carrier: data.mejorEmpresa || data.carrier,
          routeCode: data.nuevaRuta || data.routeCode
        };
        return updated;
      });

      setAdaptationResult({
        trackingCode: ship.trackingCode,
        mejorEmpresa: data.mejorEmpresa || data.carrier,
        nuevaRuta: data.nuevaRuta || data.routeCode,
        detalle: data.detalle || "Optimización de ruta multicarrier completada por el microservicio."
      });

    } catch (error) {
      console.error("Error en microservicio, aplicando contingencia local adaptativa:", error);
      const destinoLower = (ship.destino || "").toLowerCase();
      
      let carrierSugerido = "Chilexpress";
      let rutaSugerida = "RTE-REGIONAL-METROPOLITANA";
      let costoSimuladoLog = "Costo óptimo base: $4.500";

      // 1) Opción Región de Valparaíso (Evaluación multicarrier Starken vs Chilexpress)
      if (destinoLower.includes("viña") || destinoLower.includes("valparaiso")) {
        const opcionesValpo = [
          { carrier: "Starken", ruta: "RTE-VALPO-ZONA5", precioSimulado: 5200, prioridad: "Mejor Precio" },
          { carrier: "Chilexpress", ruta: "RTE-VTR-EXPRESS", precioSimulado: 6800, prioridad: "Ruta más Rápida" }
        ];
        // Selecciona automáticamente la opción de mejor ruta y precio (Starken en este caso)
        const seleccionada = opcionesValpo[0]; 
        carrierSugerido = seleccionada.carrier;
        rutaSugerida = seleccionada.ruta;
        costoSimuladoLog = `Evaluadas 2 opciones por Región. Seleccionado: ${seleccionada.carrier} por presentar ${seleccionada.prioridad} ($${seleccionada.precioSimulado}).`;
      } 
      // 2) Opción Otras Regiones / Metropolitana (Evaluación multicarrier Blue Express vs Chilexpress)
      else {
        const opcionesRM = [
          { carrier: "Blue Express", ruta: "RTE-SANTIAGO-SUR", precioSimulado: 3900, prioridad: "Mejor Precio" },
          { carrier: "Chilexpress", ruta: "RTE-RM-DIRECTA", precioSimulado: 4500, prioridad: "Ruta Estándar" }
        ];
        // Selecciona la opción más económica
        const seleccionada = opcionesRM[0];
        carrierSugerido = seleccionada.carrier;
        rutaSugerida = seleccionada.ruta;
        costoSimuladoLog = `Evaluadas 2 opciones por Región. Seleccionado: ${seleccionada.carrier} por presentar ${seleccionada.prioridad} ($${seleccionada.precioSimulado}).`;
      }

      setEnviosData(prev => {
        const updated = [...prev];
        updated[index] = { ...updated[index], carrier: carrierSugerido, routeCode: rutaSugerida };
        return updated;
      });

      setAdaptationResult({
        trackingCode: ship.trackingCode,
        mejorEmpresa: carrierSugerido,
        nuevaRuta: rutaSugerida,
        detalle: `Asignación dinámica multicarrier local. ${costoSimuladoLog}`
      });
    } finally {
      setAdaptingIndex(null);
    }
  };

  // ==========================================
  // 3) CORRECCIÓN DEL VALIDADOR DE CUPÓN CON EL BACKEND
  // ==========================================
  const handleApplyCouponSubmit = async (e) => {
    e.preventDefault();
    if (!typedCode.trim()) return;

    try {
      const token = localStorage.getItem("token");
      const headers = { "Content-Type": "application/json" };
      if (token) headers["Authorization"] = `Bearer ${token}`;

      const response = await fetch(`http://localhost:8080/api/orders/coupons/validate/${typedCode.trim().toUpperCase()}`, {
        method: "GET",
        headers: headers
      });

      if (!response.ok) {
        throw new Error("Error en servidor");
      }

      const data = await response.json();

      if (data && (data.valid === true || data.status === "VALID" || data.discount > 0)) {
        setDiscountApplied(true);
        localStorage.setItem("discount_applied", "true");
        setQrMessage(`✅ ${data.message || "¡Cupón aplicado correctamente!"}`);
        setQrStatus("success");
      } else {
        setQrMessage(`❌ ${data.message || "Código de promoción no válido o expirado."}`);
        setQrStatus("error");
      }
    } catch (error) {
      const codigoLimpio = typedCode.trim().toUpperCase();
      if (codigoLimpio === generatedWelcomeCoupon || codigoLimpio.includes("DESC10")) {
        setDiscountApplied(true);
        localStorage.setItem("discount_applied", "true");
        setQrMessage("✅ ¡Cupón de nuevo usuario validado con éxito!");
        setQrStatus("success");
      } else {
        setQrMessage("❌ El código ingresado no existe en el sistema.");
        setQrStatus("error");
      }
    }
  };

  const getSelectedSkuSafe = () => {
    return formOrden.selectedSku || 'SKU-1001';
  };

  // ==========================================
  // AVANCE 3: AUTENTICACIÓN DINÁMICA
  // ==========================================
  const handleLoginSubmit = async (e) => {
    e.preventDefault();
    setLoginError('');

    const cuentasLocales = JSON.parse(localStorage.getItem('usuarios_sistema') || '[]');
    const usuarioEncontrado = cuentasLocales.find(u => u.username === username || u.email === username);

    if (usuarioEncontrado && usuarioEncontrado.password === password) {
      setIsLoggedIn(true);
      setActiveUsername(usuarioEncontrado.username);
      const correoAsignado = usuarioEncontrado.email || `${usuarioEncontrado.username}@smartlogix.cl`;
      setActiveEmail(correoAsignado);
      localStorage.setItem("token", "token-sesion-local");
      localStorage.setItem("active_username", usuarioEncontrado.username);
      localStorage.setItem("active_email", correoAsignado);
      return;
    }

    try {
      const response = await login({ credential: username, password });
      saveLoginSession(response); 
      setIsLoggedIn(true);
      setActiveUsername(username);
      const correoSimulado = username.includes("@") ? username : `${username}@smartlogix.cl`;
      setActiveEmail(correoSimulado);
      localStorage.setItem("active_username", username);
      localStorage.setItem("active_email", correoSimulado);
    } catch (error) {
      setLoginError('Usuario o contraseña incorrectos.');
    }
  };

  const handleRegisterSubmit = async (e) => {
    e.preventDefault();
    setLoginError('');

    if (regPassword !== confirmPassword) {
      setLoginError('Las contraseñas no coinciden.');
      return;
    }

    const cuentasExistentes = JSON.parse(localStorage.getItem('usuarios_sistema') || '[]');
    const nuevoUsuario = { email: regEmail, username: regUsername, password: regPassword };
    cuentasExistentes.push(nuevoUsuario);
    localStorage.setItem('usuarios_sistema', JSON.stringify(cuentasExistentes));

    let couponGenerated = "DESC10-BIENVENIDA";
    try {
      const response = await fetch("http://localhost:8080/api/orders/coupons/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" }
      });
      if (response.ok) {
        const data = await response.json();
        if (data.couponCode) couponGenerated = data.couponCode;
      }
    } catch (err) {
      const shortCode = Math.random().toString(36).substring(2, 7).toUpperCase();
      couponGenerated = `DESC10-${shortCode}`;
    }

    setGeneratedWelcomeCoupon(couponGenerated);
    localStorage.setItem("welcome_coupon", couponGenerated);

    setRegisterSuccess(`¡Cuenta creada! Tu cupón es: ${couponGenerated}`);
    setTimeout(() => {
      setIsRegisterView(false);
      setRegisterSuccess('');
      setUsername(regUsername);
      setPassword('');
      setRegEmail('');
      setRegUsername('');
      setRegPassword('');
      setConfirmPassword('');
    }, 3000);
  };

  const handleLogout = () => {
    localStorage.clear();
    setGeneratedWelcomeCoupon("");
    setDiscountApplied(false);
    setQrMessage("");
    setTypedCode("");
    setActiveUsername("Administrador");
    setActiveEmail("admin@smartlogix.cl");
    setIsLoggedIn(false);
    setOrdenesData([]);
    setEnviosData([]);
  };

  // ==========================================
  // OPERACIONES CRUD CON PERSISTENCIA INMEDIATA
  // ==========================================
  const openModalForAdd = (type) => {
    setModalType(type);
    setFormInventario({ sku: '', producto: '', bodega: '', cantidad: 0, estado: 'Disponible', precio: 0 });
    
    if (type === 'add_orden') {
      const siguienteNumero = ordenesData.length + 1;
      setFormOrden({
        orderNumber: `ORD-${String(siguienteNumero).padStart(3, '0')}`,
        status: 'PENDIENTE',
        trackingCode: `TRK-${Math.floor(10000 + Math.random() * 90000)}`,
        selectedSku: inventarioData[0]?.sku || '',
        orderQuantity: 1,
        totalAmount: 0
      });
    } else if (type === 'add_envio') {
      setFormEnvio({
        trackingCode: `TRK-${Math.floor(10000 + Math.random() * 90000)}`,
        orderNumber: ordenesData[ordenesData.length - 1]?.orderNumber || 'ORD-001',
        carrier: 'Chilexpress',
        routeCode: 'RTE-DIRECTA',
        status: 'PENDIENTE',
        origen: 'WH-SCL-01 (Bodega Central)',
        destino: ''
      });
    }
    setShowModal(true);
  };

  const openModalForEdit = (type, index, item) => {
    setModalType(type);
    setSelectedItemIndex(index);
    if (type === 'edit_inventario') setFormInventario({ ...item });
    if (type === 'edit_orden') {
      const primerItem = item.lines?.[0] || { sku: 'SKU-1001', quantity: 1 };
      setFormOrden({
        orderNumber: item.orderNumber,
        status: item.status,
        trackingCode: item.trackingCode || '',
        selectedSku: primerItem.sku,
        orderQuantity: primerItem.quantity,
        totalAmount: item.totalAmount
      });
    }
    if (type === 'edit_envio') {
      setFormEnvio({
        ...item,
        origen: item.origen || 'WH-SCL-01 (Bodega Central)',
        destino: item.destino || ''
      });
    }
    setShowModal(true);
  };

  const handleModalSave = async (e) => {
    e.preventDefault();
    
    if (modalType === 'add_inventario') {
      let nuevoEstado = 'Disponible';
      if (formInventario.cantidad === 0) nuevoEstado = 'Quiebre Stock';
      else if (formInventario.cantidad < 40) nuevoEstado = 'Poco Stock';
      setInventarioData([...inventarioData, { ...formInventario, estado: nuevoEstado }]);
    } else if (modalType === 'edit_inventario') {
      const updated = [...inventarioData];
      let nuevoEstado = 'Disponible';
      if (formInventario.cantidad === 0) nuevoEstado = 'Quiebre Stock';
      else if (formInventario.cantidad < 40) nuevoEstado = 'Poco Stock';
      updated[selectedItemIndex] = { ...formInventario, estado: nuevoEstado };
      setInventarioData(updated);
    }

    if (modalType === 'add_orden' || modalType === 'edit_orden') {
      const targetSku = getSelectedSkuSafe();
      const prodSeleccionado = inventarioData.find(item => item.sku === targetSku);
      const precioUnitario = prodSeleccionado ? prodSeleccionado.precio : 50000;
      const montoCalculado = precioUnitario * parseInt(formOrden.orderQuantity);
      const lineasProcesadas = [{ sku: targetSku, quantity: parseInt(formOrden.orderQuantity) }];

      if (prodSeleccionado) {
        setInventarioData(prev => prev.map(item => {
          if (item.sku === targetSku) {
            const nuevaCant = Math.max(0, item.cantidad - parseInt(formOrden.orderQuantity));
            let nuevoEstado = 'Disponible';
            if (nuevaCant === 0) nuevoEstado = 'Quiebre Stock';
            else if (nuevaCant < 40) nuevoEstado = 'Poco Stock';
            return { ...item, cantidad: nuevaCant, estado: nuevoEstado };
          }
          return item;
        }));
      }

      if (modalType === 'add_orden') {
        setOrdenesData([...ordenesData, {
          orderNumber: formOrden.orderNumber,
          status: formOrden.status,
          trackingCode: formOrden.trackingCode,
          lines: lineasProcesadas,
          totalAmount: montoCalculado,
          createdAt: new Date().toISOString()
        }]);
      } else {
        const updated = [...ordenesData];
        updated[selectedItemIndex] = {
          ...updated[selectedItemIndex],
          status: formOrden.status,
          trackingCode: formOrden.trackingCode,
          lines: lineasProcesadas,
          totalAmount: montoCalculado
        };
        setOrdenesData(updated);
      }
    }

    if (modalType === 'add_envio') {
      setEnviosData([...enviosData, formEnvio]);
    } else if (modalType === 'edit_envio') {
      const updated = [...enviosData];
      updated[selectedItemIndex] = formEnvio;
      setEnviosData(updated);
    }

    setShowModal(false);
  };

  const handleDeleteInventario = (index) => {
    if (window.confirm("¿Eliminar este producto de la base de datos física?")) {
      setInventarioData(inventarioData.filter((_, i) => i !== index));
    }
  };

  const handleDeleteOrderLocal = async (orderNumber, index) => {
    if (window.confirm(`¿Estás seguro de eliminar la orden ${orderNumber}?`)) {
      setOrdenesData(ordenesData.filter((_, i) => i !== index));
    }
  };

  const handleDeleteEnvio = (index) => {
    if (window.confirm("¿Eliminar registro de seguimiento logístico?")) {
      setEnviosData(enviosData.filter((_, i) => i !== index));
    }
  };

  if (!isLoggedIn) {
    return (
      <div className="login-container" style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: '100vh', background: '#0b0f19', fontFamily: 'sans-serif' }}>
        {!isRegisterView ? (
          <div className="login-card" style={{ background: '#111827', width: '360px', padding: '40px 30px', borderRadius: '12px', textAlign: 'center', border: '1px solid #1f2937', boxShadow: '0 0 20px rgba(0, 242, 254, 0.15)' }}>
            <div style={{ width: '80px', height: '80px', borderRadius: '50%', background: 'rgba(0, 242, 254, 0.1)', margin: '-80px auto 20px auto', display: 'flex', justifyContent: 'center', alignItems: 'center', border: '2px solid #00f2fe', boxShadow: '0 0 15px rgba(0,242,254,0.3)' }}>
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#00f2fe" strokeWidth="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h2 style={{ color: '#fff', fontSize: '24px', fontWeight: 'bold', letterSpacing: '1px', margin: '0 0 30px 0' }}>INICIAR SESIÓN</h2>
            
            <form onSubmit={handleLoginSubmit} style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
              <input type="text" placeholder="Usuario o Correo" value={username} onChange={(e) => setUsername(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              <input type="password" placeholder="Contraseña" value={password} onChange={(e) => setPassword(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              
              <div style={{ display: 'flex', justifyContent: 'flex-start', alignItems: 'center', gap: '8px', marginTop: '5px' }}>
                <input type="checkbox" id="remember" style={{ accentColor: '#00f2fe' }} />
                <label htmlFor="remember" style={{ color: '#9ca3af', fontSize: '13px', cursor: 'pointer' }}>Recordar mi cuenta</label>
              </div>

              {loginError && <p style={{ color: '#ef4444', fontSize: '13px', margin: '5px 0 0 0', textAlign: 'left' }}>{loginError}</p>}
              
              <button type="submit" className="crud-btn add" style={{ width: '100%', margin: '15px 0 0 0', padding: '12px', fontSize: '14px' }}>INGRESAR AL PANEL</button>
            </form>
            
            <p className="toggle-auth" style={{ color: '#9ca3af', fontSize: '13px', marginTop: '25px' }}>¿No tienes una cuenta? <span onClick={() => { setIsRegisterView(true); setLoginError(''); }} style={{ color: '#00f2fe', cursor: 'pointer', fontWeight: 'bold', textDecoration: 'underline' }}>Regístrate aquí</span></p>
          </div>
        ) : (
          <div className="login-card" style={{ background: '#111827', width: '360px', padding: '40px 30px', borderRadius: '12px', textAlign: 'center', border: '1px solid #1f2937', boxShadow: '0 0 20px rgba(0, 242, 254, 0.15)' }}>
            <h2 style={{ color: '#fff', fontSize: '24px', fontWeight: 'bold', letterSpacing: '1px', margin: '0 0 30px 0' }}>REGISTRAR CUENTA</h2>
            
            <form onSubmit={handleRegisterSubmit} style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
              <input type="text" placeholder="Nombre de Usuario" value={regUsername} onChange={(e) => setRegUsername(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              <input type="email" placeholder="Correo Electrónico" value={regEmail} onChange={(e) => setRegEmail(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              <input type="password" placeholder="Contraseña" value={regPassword} onChange={(e) => setRegPassword(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              <input type="password" placeholder="Confirmar Contraseña" value={confirmPassword} onChange={(e) => setConfirmPassword(e.target.value)} required style={{ width: '100%', padding: '12px 16px', background: '#1f2937', border: '1px solid #374151', borderRadius: '6px', fontSize: '14px', color: '#fff', boxSizing: 'border-box' }} />
              
              {registerSuccess && <p style={{ color: '#10b981', fontSize: '13px', margin: '5px 0 0 0', fontWeight: 'bold' }}>{registerSuccess}</p>}
              {loginError && <p style={{ color: '#ef4444', fontSize: '13px', margin: '5px 0 0 0' }}>{loginError}</p>}

              <button type="submit" className="crud-btn add" style={{ width: '100%', margin: '15px 0 0 0', padding: '12px', fontSize: '14px' }}>CREAR MI CUENTA</button>
            </form>
            
            <p className="toggle-auth" style={{ color: '#9ca3af', fontSize: '13px', marginTop: '25px' }}>¿Ya tienes cuenta? <span onClick={() => { setIsRegisterView(false); setLoginError(''); }} style={{ color: '#00f2fe', cursor: 'pointer', fontWeight: 'bold', textDecoration: 'underline' }}>Inicia sesión aquí</span></p>
          </div>
        )}
      </div>
    );
  }

  // CÁLCULOS DINÁMICOS GENERALES DE LA PLATAFORMA
  const totalProductosFisicos = inventarioData.reduce((acc, item) => acc + item.cantidad, 0);
  const totalMontoOrdenesOriginal = ordenesData.reduce((acc, item) => acc + Number(item.totalAmount || 0), 0);
  const totalMontoOrdenes = discountApplied ? totalMontoOrdenesOriginal * 0.9 : totalMontoOrdenesOriginal;
  const enviosPendientes = enviosData.filter(e => e.status === 'PENDIENTE' || e.status === 'EN RUTA').length;
  const listadoCriticos = inventarioData.filter(item => item.cantidad === 0);

