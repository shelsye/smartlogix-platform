import { useEffect, useState } from "react";
import { getOrders, deleteOrder } from "../services/ordersService";
import Navbar from "../components/Navbar";
import "../App.css";

function OrdersPage() {
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);

  // Estados para el Modal de Crear Orden y Validación de Código
  const [showCreateModal, setShowCreateModal] = useState(false);
  const [sku, setSku] = useState("SKU-1001");
  const [cantidad, setCantidad] = useState(1);
  const [cuponInput, setCuponInput] = useState("");
  const [descuentoAplicado, setDescuentoAplicado] = useState(false);
  const [msgCupon, setMsgCupon] = useState("");

  // Estados obligatorios para pasar las validaciones @NotBlank de Spring Boot
  const [customerName, setCustomerName] = useState("Cliente General");
  const [customerEmail, setCustomerEmail] = useState("contacto@smartlogix.cl");
  const [shippingAddress, setShippingAddress] = useState("Av. Vitacura 1234, Santiago");

  const preciosReferencia = {
    "SKU-1001": 89990,
    "SKU-2001": 119990,
    "SKU-3001": 249990,
    "SKU-4004": 489990,
    "SKU-5012": 45990
  };

  useEffect(() => {
    async function loadOrders() {
      try {
        const [data] = await Promise.all([
          getOrders(),
          new Promise((resolve) => setTimeout(resolve, 1000))
        ]);
        setOrders(data || []);
      } catch (error) {
        console.error(error);
      } finally {
        setLoading(false);
      }
    }
    loadOrders();
  }, []);

  const handleDelete = async (orderNumber) => {
    if (window.confirm(`¿Estás seguro de eliminar la orden ${orderNumber}?`)) {
      try {
        await deleteOrder(orderNumber);
        setOrders(orders.filter((order) => order.orderNumber !== orderNumber));
      } catch (error) {
        console.error("Error al eliminar la orden:", error);
        alert("Hubo un problema al intentar eliminar la orden.");
      }
    }
  };

  const handleValidarCupon = () => {
    if (cuponInput.trim().toUpperCase() === "NUEVO10") {
      setDescuentoAplicado(true);
      setMsgCupon("✅ Código NUEVO10 validado con éxito. 10% de descuento aplicado.");
    } else {
      setDescuentoAplicado(false);
      setMsgCupon("❌ Código inválido o expirado.");
    }
  };

  const handleCrearOrdenSubmit = async (e) => {
    e.preventDefault();
    
    const basePrice = preciosReferencia[sku] || 50000;

    // Construcción exacta del payload exigido por CreateOrderRequest.java
    const nuevaOrdenPayload = {
      customerName: customerName,
      customerEmail: customerEmail,
      shippingAddress: shippingAddress,
      lines: [
        {
          sku: sku,
          quantity: parseInt(cantidad),
          unitPrice: basePrice
        }
      ],
      couponCode: descuentoAplicado ? "NUEVO10" : ""
    };

    try {
      const response = await fetch("http://localhost:8080/api/orders", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(nuevaOrdenPayload)
      });

      if (!response.ok) throw new Error("Error creando orden en el servidor");
      
      alert("¡Orden registrada exitosamente!");
      setShowCreateModal(false);
      
      setCuponInput("");
      setDescuentoAplicado(false);
      setMsgCupon("");
      setCantidad(1);

      const refreshData = await getOrders();
      setOrders(refreshData || []);

    } catch (err) {
      console.error(err);
      alert("Error al conectar con order-service.");
    }
  };

  if (loading) {
    return (
      <div className="inventory-loading">
        <div className="spinner"></div>
        <h2>Sincronizando Libro de Órdenes...</h2>
      </div>
    );
  }

  return (
    <div className="inventory-container">
      <Navbar />

      <section className="inventory-stats" style={{ marginTop: "30px" }}>
        <div className="stat-card">
          <h3>Órdenes Totales</h3>
          <p>{orders.length}</p>
        </div>
      </section>

      <section className="inventory-table-section">
        <div className="table-header">
          <h2>Registro de Órdenes de Compra</h2>
          <button 
            className="add-product-btn" 
            style={{ backgroundColor: '#00f2fe', color: '#000', fontWeight: 'bold' }}
            onClick={() => setShowCreateModal(true)}
          >
            + Crear Nueva Orden
          </button>
        </div>
        <table className="inventory-table">
          <thead>
            <tr>
              <th>Número de Orden</th>
              <th>Estado</th>
              <th>Tracking Asociado</th>
              <th>Productos Solicitados</th>
              <th>Fecha Registro</th>
              <th>Monto Total</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {orders.map((order, idx) => (
              <tr key={order.orderNumber || idx}>
                <td className="sku">{order.orderNumber}</td>
                <td>
                  <span className={`status-badge ${order.status?.toLowerCase()}`}>
                    {order.status}
                  </span>
                </td>
                <td>
                  <code style={{ color: '#38bdf8' }}>{order.trackingCode || "Generando..."}</code>
                </td>
                <td>
                  {order.lines && order.lines.map((line, i) => (
                    <div key={i} style={{ fontSize: "13px" }}>
                      📦 {line.sku} <span style={{ color: '#ff9f43' }}>(x{line.quantity})</span>
                    </div>
                  ))}
                </td>
                <td>{order.createdAt ? new Date(order.createdAt).toLocaleDateString("es-ES") : "Reciente"}</td>
                <td>
                  <span style={{ color: '#4ade80', fontWeight: 'bold' }}>
                    ${order.totalAmount ? order.totalAmount.toLocaleString('es-CL') : '0'}
                  </span>
                </td>
                <td>
                  <button
                    style={{ backgroundColor: "#ff4d4f", color: "white", border: "none", padding: "5px 10px", borderRadius: "4px", cursor: "pointer", fontWeight: "bold" }}
                    onClick={() => handleDelete(order.orderNumber)}
                  >
                    Eliminar
                  </button>
                </td>
              </tr>
            ))}
            
            {orders.length === 0 && (
              <tr>
